<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f5f7fb;
}

/* Navbar */

.navbar{
    background:#2563eb;
    color:#fff;
    padding:18px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.navbar h2{
    font-size:28px;
}

.navbar a{
    text-decoration:none;
    color:white;
    background:#dc2626;
    padding:10px 20px;
    border-radius:8px;
    font-weight:bold;
}

.navbar a:hover{
    background:#b91c1c;
}

/* Hero */

.hero{
    text-align:center;
    padding:50px 20px;
}

.hero h1{
    font-size:40px;
    color:#1f2937;
    margin-bottom:10px;
}

.hero p{
    color:#6b7280;
    font-size:18px;
}

/* Cards */

.container{
    width:90%;
    max-width:1200px;
    margin:40px auto;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 8px 20px rgba(0,0,0,.08);
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card h2{
    margin-bottom:15px;
    color:#2563eb;
}

.card p{
    color:#555;
    margin-bottom:25px;
    line-height:1.5;
}

.card a{
    display:inline-block;
    text-decoration:none;
    background:#2563eb;
    color:white;
    padding:10px 20px;
    border-radius:8px;
}

.card a:hover{
    background:#1d4ed8;
}

/* Footer */

footer{
    margin-top:50px;
    text-align:center;
    padding:20px;
    color:#777;
}
</style>

</head>
<body>

<nav class="navbar">
    <h2>My Dashboard</h2>

    <a href="/">Logout</a>
</nav>

<section class="hero">
    <h1>Welcome 👋</h1>
    <p>Select an option below to continue.</p>
</section>

<div class="container">

    <div class="grid">

        <div class="card">
            <h2>👤 My Profile</h2>
            <p>View and edit your personal information.</p>
            <a href="#">Open</a>
        </div>

        <div class="card">
            <h2>⚙ Settings</h2>
            <p>Update password, username and preferences.</p>
            <a href="#">Open</a>
        </div>

        <div class="card">
            <h2>📁 Documents</h2>
            <p>Manage and upload your files securely.</p>
            <a href="#">Open</a>
        </div>

        <div class="card">
            <h2>📊 Dashboard</h2>
            <p>View statistics and activity.</p>
            <a href="#">Open</a>
        </div>

        <div class="card">
            <h2>📨 Messages</h2>
            <p>Check notifications and messages.</p>
            <a href="#">Open</a>
        </div>

        <div class="card">
            <h2>🛠 Support</h2>
            <p>Need help? Contact our support team.</p>
            <a href="#">Open</a>
        </div>

    </div>

</div>

<footer>
    © 2026 My Application. All Rights Reserved.
</footer>

</body>
</html>